{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "steemtools",
  "default_locale": "en",
  "version": "1.0.0",
  "action": {
    "default_icon": "icon.png",
    "default_title": "Steem Tools",
    "default_popup": "main.html"
  },
  "author": "justyy<dr.zhihua.lai@gmail.com>",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "description": "__MSG_appDesc__",
  "web_accessible_resources": [
    {
      "resources": ["js/*", "images/*", "css/*", "bs/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self'; connect-src https: wss:;"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "tabs", "contextMenus"],
  "host_permissions": ["<all_urls>"]
}
