{
  "manifest_version": 2,
  "name": "Steem Tools",
  "short_name": "steemtools",
  "default_locale": "en",
  "version": "1.0.0",
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Steem Tools",
    "default_popup": "main.html"
  },
  "author": "justyy<dr.zhihua.lai@gmail.com>",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "description": "Handy tools for Steem users: blockchain & account insights, delegations, downvotes, witness lookup, a Steem-JS console, a multi-send wallet and more.",
  "web_accessible_resources": ["js/*", "images/*", "css/*", "bs/*"],
  "content_security_policy": "connect-src https://*; script-src 'self' 'unsafe-eval'; object-src 'self'",
  "background": {
    "scripts": ["js/background.js", "js/context.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "tabs", "contextMenus", "<all_urls>"]
}
