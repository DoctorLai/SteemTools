{
  "name": "steem-tools",
  "version": "1.0.0",
  "description": "A Chrome extension packed with handy tools for Steem users: blockchain & account insights, delegations, downvotes, witness lookup, a Steem-JS console, a multi-send wallet and more.",
  "author": "justyy <dr.zhihua.lai@gmail.com> (https://steemyy.com)",
  "license": "MIT",
  "homepage": "https://github.com/DoctorLai/SteemTools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoctorLai/SteemTools.git"
  },
  "bugs": {
    "url": "https://github.com/DoctorLai/SteemTools/issues"
  },
  "keywords": [
    "steem",
    "steemit",
    "chrome-extension",
    "blockchain",
    "cryptocurrency",
    "browser-extension"
  ],
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "coverage": "jest --coverage",
    "check": "npm run lint && npm run format:check && npm run test:coverage",
    "build": "node scripts/build.js",
    "prebuild": "npm run test:coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
